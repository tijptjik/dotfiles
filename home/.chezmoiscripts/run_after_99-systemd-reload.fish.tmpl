#!/usr/bin/env fish
#
# This script is run by chezmoi on `chezmoi apply`.
# It ensures that systemd user services and timers are reloaded and enabled.
source "{{ .chezmoi.sourceDir }}/.chezmoihelpers/status.fish"

if command -q gum; and isatty stdout
    gum style --foreground 12 --bold "Systemd User Units"
else
echo "Systemd User Units"
end
echo

function user_units_need_reload
    set -l need_reload (systemctl --user show --property=NeedDaemonReload --value 2>/dev/null)
    test "$need_reload" = yes
end

function unit_needs_enable_now
    set -l unit $argv[1]
    if not systemctl --user --quiet is-enabled "$unit" 2>/dev/null
        return 0
    end
    if not systemctl --user --quiet is-active "$unit" 2>/dev/null
        return 0
    end
    return 1
end

function units_need_enable_now
    for unit in $argv
        if unit_needs_enable_now "$unit"
            return 0
        end
    end
    return 1
end

function configure_common_user_units
    systemctl --user daemon-reload
    systemctl --user enable --now backup-packages.timer
end

if user_units_need_reload; or unit_needs_enable_now backup-packages.timer
    stage_note "Systemd User Units [Common]" CONFIG "Common Units" configured configure_common_user_units
else
    __stage_label_note SKIP "✓" "Common Units" "no changes"
end

{{ if .isClient -}}

set client_services "hyprpolkitagent.service" "hypridle.service" "hyprpaper.service" "hyprvoice.service"

function configure_client_user_units
    for service in $argv
        systemctl --user enable --now $service
    end
end

if user_units_need_reload; or units_need_enable_now $client_services
    stage_note "Systemd User Units [Clients]" CONFIG "Clients Units" configured configure_client_user_units $client_services
else
    __stage_label_note SKIP "✓" "Clients Units" "no changes"
end

# This unit is deliberately enabled without --now: starting it during a
# chezmoi apply would lock the currently active graphical session.  systemd
# starts it automatically with graphical-session.target on the next login.
function configure_hyprlock_login_unit
    systemctl --user enable hyprlock-login.service
end

if user_units_need_reload; or not systemctl --user --quiet is-enabled hyprlock-login.service 2>/dev/null
    stage_note "Systemd User Unit [Hyprlock Login]" CONFIG "Hyprlock Login" configured configure_hyprlock_login_unit
else
    __stage_label_note SKIP "✓" "Hyprlock Login" "no changes"
end

{{- end }}
