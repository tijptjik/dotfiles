#!/usr/bin/env fish
#
# This script is run by chezmoi on `chezmoi apply`.
# It ensures that systemd user services and timers are reloaded and enabled.
source "{{ .chezmoi.sourceDir }}/.chezmoihelpers/status.fish"

if command -q gum; and isatty stdout
    gum style --foreground 14 --bold "Systemd User Units"
else
    echo "Systemd User Units"
end
echo

function configure_common_user_units
    systemctl --user daemon-reload
    systemctl --user enable --now backup-packages.timer
end

stage_note "Systemd User Units [Common]" CONFIG "Common Units" configured configure_common_user_units

{{ if .isClient -}}

set client_services "hyprpolkitagent.service" "hypridle.service" "hyprsunset.service" "hyprpaper.service" "hyprvoice.service"

function configure_client_user_units
    for service in $argv
        systemctl --user enable --now $service
    end
end

stage_note "Systemd User Units [Clients]" CONFIG "Clients Units" configured configure_client_user_units $client_services

# This unit is deliberately enabled without --now: starting it during a
# chezmoi apply would lock the currently active graphical session.  systemd
# starts it automatically with graphical-session.target on the next login.
function configure_hyprlock_login_unit
    systemctl --user enable hyprlock-login.service
end

stage_note "Systemd User Unit [Hyprlock Login]" CONFIG "Hyprlock Login" configured configure_hyprlock_login_unit

{{- end }}
