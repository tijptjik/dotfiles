#!/usr/bin/env fish
if test "$CHEZUP_SKIP_PREFLIGHT" = "1"
    exit 0
end

source "{{ .chezmoi.sourceDir }}/.chezmoihelpers/status.fish"

function check_command --argument-names subject command_name
    if command -v "$command_name" >/dev/null 2>&1
        __stage_label_note CHECK "✓" "$subject" "available"
    else
        __stage_label_note SKIP "-" "$subject" "available"
    end
end

function check_file --argument-names subject path
    if test -f "$path"
        __stage_label_note CHECK "✓" "$subject" "available"
    else
        __stage_label_note SKIP "✓" "$subject" "not configured"
    end
end

check_command "Bitwarden Secrets Manager CLI" bws
check_file "Bitwarden Access Token" "$HOME/.config/bws/environment"
check_file "Chezmoi Decryption Key" "$HOME/.keys/chezmoi.txt"
check_command "Gum" gum
check_command "Fish" fish
check_command "Bun" bun
check_command "FNM" fnm
check_command "Herdr" herdr
