#!/usr/bin/env fish
source "{{ .chezmoi.sourceDir }}/.chezmoihelpers/status.fish"

# Check if fish is installed
if not command -v -q fish
    __stage_result CONFIG "Default shell"
    exit 0
end

# Get the path to the fish executable
set -l fish_path (which fish)

# Check if the user's shell is already fish
if string match -q -- "$fish_path" "$SHELL"
    __stage_result CONFIG "Default shell"
    exit 0
end

function configure_default_fish_shell --argument-names fish_path username
    if not grep -q "^$fish_path\$" /etc/shells
        echo $fish_path | sudo tee -a /etc/shells >/dev/null
    end

    sudo chsh -s $fish_path $username
end

stage "default shell" CONFIG "Default shell" configure_default_fish_shell "$fish_path" "{{ .chezmoi.username }}"
