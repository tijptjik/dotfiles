#!/usr/bin/env fish
source "{{ .chezmoi.sourceDir }}/.chezmoihelpers/status.fish"

{{ if .isLaptop }}

# This script applies specific multimedia and hardware fixes for the
# Lenovo 82T0 Yoga Slim 9 14IAP7.

# --- Configuration ---
set -l PRODUCT_NAME "82T0"
set -l I915_CONF_PATH "/etc/modprobe.d/i915.conf"
set -l SND_CONF_PATH "/etc/modprobe.d/snd.conf"

# --- Functions ---

function get_product_name
    if test -f /sys/class/dmi/id/product_name
        return (cat /sys/class/dmi/id/product_name)
    end
    return "Unknown"
end

function packages_installed
    set -l packages_to_check \
        intel-media-driver \
        intel-gpu-firmware \
        libva \
        libva-utils \
        gstreamer1-vaapi \
        ffmpeg \
        intel-gpu-tools \
        mesa-dri-drivers \
        mpv

    for pkg in $packages_to_check
        if not rpm -q $pkg >/dev/null 2>&1
            return 1
        end
    end
    return 0
end

# --- Main Logic ---

# Check if this is the target machine
if test (get_product_name) != "$PRODUCT_NAME"
    __stage_result CONFIG "Lenovo $PRODUCT_NAME setup"
    exit 0
end

function install_lenovo_multimedia_packages
    sudo dnf groupinstall -y multimedia
    sudo dnf install -y \
        intel-media-driver \
        intel-gpu-firmware \
        libva \
        libva-utils \
        gstreamer1-vaapi \
        ffmpeg \
        intel-gpu-tools \
        mesa-dri-drivers \
        mpv

    sudo dnf swap -y ffmpeg-free ffmpeg --allowerasing
end

function configure_i915_graphics --argument-names i915_conf_path
    if test ! -f "$i915_conf_path"
        set -l i915_conf "options i915 enable_guc=3\noptions i915 enable_fbc=1"
        echo -e $i915_conf | sudo tee "$i915_conf_path" >/dev/null
    end
end

function configure_lenovo_sound --argument-names snd_conf_path
    if test ! -f "$snd_conf_path"
        set -l snd_conf "options snd_intel_dspcfg dsp_driver=1\noptions snd_hda_intel model=alc287-yoga9-bass-spk-pin"
        echo -e $snd_conf | sudo tee "$snd_conf_path" >/dev/null
    end
end

function remove_rhgb_kernel_arg
    sudo grubby --remove-args="rhgb" --update-kernel=/boot/vmlinuz-****.fc**.x86_64
end

if not packages_installed
    stage "Lenovo $PRODUCT_NAME multimedia packages" INSTALL "Lenovo $PRODUCT_NAME multimedia packages" install_lenovo_multimedia_packages
else
    __stage_result INSTALL "Lenovo $PRODUCT_NAME multimedia packages"
end

stage "Lenovo $PRODUCT_NAME graphics configuration" CONFIG "Lenovo $PRODUCT_NAME graphics" configure_i915_graphics "$I915_CONF_PATH"
stage "Lenovo $PRODUCT_NAME sound configuration" CONFIG "Lenovo $PRODUCT_NAME sound" configure_lenovo_sound "$SND_CONF_PATH"
stage "kernel command line" CONFIG "Kernel command line" remove_rhgb_kernel_arg

{{ end }}
