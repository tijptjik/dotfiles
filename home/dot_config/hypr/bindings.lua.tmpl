-- -*- mode: lua; -*-
-- Sourced in ~/.config/hypr/hyprland.lua
-- #######################
-- KEY BINDINGS
-- #######################

local super_mod = "SUPER"
local tools = "$HOME/.tools"
local config = "$HOME/.config"
local helpers = require("helpers")

-- #######################
-- KEY BINDINGS : UTILS
-- #######################

local function bind_key(key, ...)
    local modifiers = { ... }
    if #modifiers == 0 then
        return key
    end

    return table.concat(modifiers, " + ") .. " + " .. key
end

local function super(key, ...)
    return bind_key(key, super_mod, ...)
end

local function ctrl(key, ...)
    return bind_key(key, "CTRL", ...)
end

local function shift(key, ...)
    return bind_key(key, "SHIFT", ...)
end

-- See https://wiki.hypr.land/Configuring/Basics/Binds/
-- Note : Key mappings are managed with QMK

-- Global Application Shortcuts -- i.e. call an application shortcut without focus
hl.bind(super("R"), hl.dsp.pass({ window = "class:^(com\\.obsproject\\.Studio)$" }))

-- #######################
-- KEY BINDINGS : EXIT
-- #######################

-- Close
hl.bind(super("Q"), hl.dsp.window.kill())

-- Lock
hl.bind(super("L"), hl.dsp.exec_cmd("hyprlock --grace 5"))
{{- if .isLaptop }}
hl.bind("XF86AudioMedia", hl.dsp.exec_cmd("hyprlock --config " .. config .. "/hypr/hyprlock.conf --grace 5"))
{{- end }}

-- Exit
hl.bind(super("Q", "SHIFT"), hl.dsp.exit())

-- #######################
-- KEY BINDINGS : WINDOW MANAGEMENT
-- #######################

-- Layout
-- Swaps the current window with master. If the current window is the master, swaps it with the first child.
hl.bind(super("Delete"), hl.dsp.layout("swapwithmaster"))
-- Adds a master to the master side.
hl.bind(super("Delete", "ALT"), hl.dsp.layout("addmaster"))
-- Removes a master from the master side.
hl.bind(super("Delete", "SHIFT"), hl.dsp.layout("removemaster"))
-- Grow to fill available space, or not.
hl.bind(super("O"), hl.dsp.window.pseudo())
-- Toggle full screen.
hl.bind(super("F"), hl.dsp.window.fullscreen({ mode = "maximized" }))

-- Focus
hl.bind(super("Left"), hl.dsp.focus({ direction = "l" }))
hl.bind(super("Right"), hl.dsp.focus({ direction = "r" }))
hl.bind(super("Up"), hl.dsp.focus({ direction = "u" }))
hl.bind(super("Down"), hl.dsp.focus({ direction = "d" }))

-- Move Window
hl.bind(super("Left", "CTRL"), hl.dsp.window.move({ direction = "l" }))
hl.bind(super("Right", "CTRL"), hl.dsp.window.move({ direction = "r" }))
hl.bind(super("Up", "CTRL"), hl.dsp.window.move({ direction = "u" }))
hl.bind(super("Down", "CTRL"), hl.dsp.window.move({ direction = "d" }))

-- Cycle Window
hl.bind(super("TAB"), hl.dsp.window.swap({ next = true }))
hl.bind(super("TAB", "SHIFT"), hl.dsp.window.swap({ prev = true }))
hl.bind(super("Up", "ALT"), hl.dsp.layout("cyclenext"))
hl.bind(super("Down", "ALT"), hl.dsp.layout("cycleprev"))

-- Resize Window
hl.bind(super("Left", "SHIFT"), hl.dsp.window.resize({ x = -128, y = 0, relative = true }))
hl.bind(super("Right", "SHIFT"), hl.dsp.window.resize({ x = 128, y = 0, relative = true }))
hl.bind(super("Up", "SHIFT"), hl.dsp.window.resize({ x = 0, y = -128, relative = true }))
hl.bind(super("Down", "SHIFT"), hl.dsp.window.resize({ x = 0, y = 128, relative = true }))

-- Window Mouse Manipulation
hl.bind(super("mouse:272"), hl.dsp.window.drag())
hl.bind(super("mouse:273"), hl.dsp.window.resize())

-- #######################
-- KEY BINDINGS : WORKSPACE MANAGEMENT
-- #######################

-- Workspaces
-- Special : Chat
hl.bind(ctrl("Space"), function()
    helpers.toggle_special_workspace()
end)
hl.bind(super("Space", "CTRL"), hl.dsp.window.move({ workspace = "special:chat", follow = true }))
hl.bind(shift("Space", "CTRL"), function()
    helpers.toggle_float()
end)

-- Special : Codex
hl.bind(super("Space"), function()
    helpers.toggle_special_workspace("codex")
end)

hl.bind(ctrl("Space", "ALT"), hl.dsp.workspace.toggle_special(""))
hl.bind(super("Space", "CTRL", "ALT"), hl.dsp.window.move({ workspace = "special", follow = true }))

-- Workspace Switching

-- Switch workspaces with mod + [0-9]
hl.bind(super("1"), hl.dsp.focus({ workspace = "r~1" }))
hl.bind(super("2"), hl.dsp.focus({ workspace = "r~2" }))
hl.bind(super("3"), hl.dsp.focus({ workspace = "r~3" }))
hl.bind(super("4"), hl.dsp.focus({ workspace = "r~4" }))
hl.bind(super("5"), hl.dsp.focus({ workspace = "r~5" }))
hl.bind(super("6"), hl.dsp.focus({ workspace = "r~6" }))
hl.bind(super("7"), hl.dsp.focus({ workspace = "r~7" }))
hl.bind(super("8"), hl.dsp.focus({ workspace = "r~8" }))
hl.bind(super("9"), hl.dsp.focus({ workspace = "r~9" }))
hl.bind(super("0"), hl.dsp.focus({ workspace = "r~10" }))

-- Workspace Window Sending
hl.bind(super("1", "SHIFT"), hl.dsp.window.move({ workspace = "r~1", follow = false }))
hl.bind(super("2", "SHIFT"), hl.dsp.window.move({ workspace = "r~2", follow = false }))
hl.bind(super("3", "SHIFT"), hl.dsp.window.move({ workspace = "r~3", follow = false }))
hl.bind(super("4", "SHIFT"), hl.dsp.window.move({ workspace = "r~4", follow = false }))
hl.bind(super("5", "SHIFT"), hl.dsp.window.move({ workspace = "r~5", follow = false }))
hl.bind(super("6", "SHIFT"), hl.dsp.window.move({ workspace = "r~6", follow = false }))
hl.bind(super("7", "SHIFT"), hl.dsp.window.move({ workspace = "r~7", follow = false }))
hl.bind(super("8", "SHIFT"), hl.dsp.window.move({ workspace = "r~8", follow = false }))
hl.bind(super("9", "SHIFT"), hl.dsp.window.move({ workspace = "r~9", follow = false }))
hl.bind(super("0", "SHIFT"), hl.dsp.window.move({ workspace = "r~10", follow = false }))

-- Workspace Scrolling
hl.bind(super("mouse_down"), hl.dsp.focus({ workspace = "e+1" }))
hl.bind(super("mouse_up"), hl.dsp.focus({ workspace = "e-1" }))

{{- if .isDesktop }}
-- Workspace Layout
hl.bind(super("K"), function()
    helpers.layout_zen_hypehk_mobile()
end)
{{ end }}
-- #######################
-- KEY BINDINGS : MEDIA
-- #######################

-- Volume
hl.bind("XF86AudioRaiseVolume", hl.dsp.exec_cmd("wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+"), { locked = true, repeating = true })
hl.bind("XF86AudioLowerVolume", hl.dsp.exec_cmd("wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"), { locked = true, repeating = true })
hl.bind("XF86AudioMute", hl.dsp.exec_cmd("wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"), { locked = true })
hl.bind("XF86AudioMicMute", hl.dsp.exec_cmd("wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"), { locked = true })

-- Media Controls
hl.bind("XF86AudioPlay", hl.dsp.exec_cmd("playerctl play-pause"), { locked = true })
hl.bind("XF86AudioPrev", hl.dsp.exec_cmd("playerctl previous"), { locked = true })
hl.bind("XF86AudioNext", hl.dsp.exec_cmd("playerctl next"), { locked = true })

-- #######################
-- KEY BINDINGS : HYPRSUNSET
-- #######################

hl.bind("XF86MonBrightnessDown", hl.dsp.exec_cmd("brightnessctl set 5%-"), { locked = true, repeating = true })
hl.bind("XF86MonBrightnessUp", hl.dsp.exec_cmd("brightnessctl set 5%+"), { locked = true, repeating = true })

-- #######################
-- KEY BINDINGS : HYPRVOICE
-- #######################

hl.bind(super("grave"), function()
    helpers.toggle_hyprvoice()
end)
hl.bind(super("grave", "SHIFT"), hl.dsp.exec_cmd("$HOME/.local/bin/hyprvoice cancel"))

-- #######################
-- KEY BINDINGS : LAUNCH
-- #######################

-- Hamr Launcher
hl.bind(super("Escape"), hl.dsp.exec_cmd("$HOME/.local/bin/hamr toggle"))

-- Clipboard history
hl.bind(super("V"), hl.dsp.exec_cmd("$HOME/.local/bin/hamr plugin clipboard"))

-- Applications
hl.bind(super("Return"), hl.dsp.exec_cmd("kitty -o allow_remote_control=yes"))
hl.bind(super("Backslash"), hl.dsp.exec_cmd("/opt/Telegram/Telegram"))
hl.bind(super("Backspace"), hl.dsp.exec_cmd("zen-browser"))
hl.bind(super("E"), hl.dsp.exec_cmd("nautilus"))

-- #######################
-- KEY BINDINGS : SCREENSHOTS
-- #######################

-- Hyprshot
hl.bind(super("P"), hl.dsp.exec_cmd("hyprctl keyword monitorv2.sdrbrightness 0.8;hyprshot -o ~/media/images/screenshots -m region --clipboard-only --freeze --silent;hyprctl reload"))
hl.bind(super("P", "CTRL"), hl.dsp.exec_cmd("hyprctl keyword monitorv2.sdrbrightness 0.8;hyprshot -o ~/media/images/screenshots -m window --clipboard-only --freeze --silent;hyprctl reload"))
hl.bind(super("P", "SHIFT"), hl.dsp.exec_cmd("hyprctl keyword monitorv2.sdrbrightness 0.8;hyprshot -o ~/media/images/screenshots -m region --freeze --silent;hyprctl reload"))
hl.bind(super("P", "SHIFT", "CTRL"), hl.dsp.exec_cmd("hyprctl keyword monitorv2.sdrbrightness 0.8;hyprshot -o ~/media/images/screenshots -m window --freeze --silent;hyprctl reload"))
hl.bind(super("G"), hl.dsp.exec_cmd("kitty -e " .. tools .. "/swayrec/swayrec"))
