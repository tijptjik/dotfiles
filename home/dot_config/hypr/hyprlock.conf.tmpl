# ~/.config/hypr/hyprlock.conf
source = ~/.config/hypr/colors.conf

general {
    hide_cursor = true
    ignore_empty_input = true
    immediate_render = false
    text_trim = true
    fail_timeout = 1000
}

{{- if .isLaptop }}
# The laptop panel is 3840x2400 at scale 2 (1920x1200 logical).  Keep all
# primary widgets within that 1200px logical height.
background {
    path = screenshot
    blur_passes = 3
    blur_size = 5
    brightness = 0.5
    color = $fx-magenta
}

label {
    text = cmd[update:1000] echo "$(date +"%-H:%M")"
    color = $fx-white
    font_size = 264
    font_family = ETBembo
    position = -500, 120
    halign = center
    valign = center
}

label {
    text = <span line_height="1.22" allow_breaks="true" font_weight="light">Whatever you dream you can, begin it.<br/>Boldness has genius, power and magic in it!</span>
    color = $fx-magenta
    font_size = 36
    font_family = Gotham
    position = 420, 104
    halign = center
    valign = center
}

input-field {
    size = 420, 64
    outline_thickness = 0
    dots_size = 0.24
    dots_spacing = 0.5
    dots_center = true
    font_color = $fx-white
    outer_color = rgba(fef1fd33)
    inner_color = rgba(32303e00)
    check_color = $fx-black
    fail_color = $fx-magenta
    fade_on_empty = false
    font_family = Gotham
    placeholder_text = <span allow_breaks="true" font_weight="bold" foreground="##fef1fdaa">●   ●   ●</span>
    hide_input = false
    position = 420, -170
    halign = center
    valign = center
}
{{- else if .isDesktop }}
background {
    monitor = DP-1
    path = screenshot
    blur_passes = 3
    blur_size = 5
    brightness = 0.5
    color = $fx-magenta
}

background {
    monitor = DP-2
    path = screenshot
    blur_passes = 3
    blur_size = 5
    brightness = 0.5
    color = $fx-magenta
}

label {
    monitor = DP-1
    text = cmd[update:1000] echo "$(date +"%-H:%M")"
    color = $fx-white
    font_size = 400
    font_family = Josefin Sans
    position = -720, -420
    halign = center
    valign = top
}

label {
    monitor = DP-1
    text = <span line_height="1.4" style="italic" allow_breaks="true" font_weight="light">Whatever you dream you can,<br/>begin it. Boldness has genius,<br/>power and magic in it!</span>
    color = $fx-magenta
    font_size = 56
    font_family = DiariaPro-LightItalic
    position = 640, 70
    halign = center
    valign = center
}

label {
    monitor = DP-2
    text = <span line_height="1.2" style="italic" allow_breaks="true" font_weight="light">Unto the world<br/>in grossly loving zest</span>
    color = $fx-magenta
    font_size = 72
    font_family = DiariaPro-LightItalic
    position = 0, 32
    halign = center
    valign = center
}

input-field {
    monitor = DP-1
    size = 500, 80
    outline_thickness = 0
    dots_size = 0.24
    dots_spacing = 0.5
    dots_center = true
    font_color = $fx-white
    outer_color = rgba(fef1fd33)
    inner_color = rgba(32303e00)
    check_color = $fx-black
    fail_color = $fx-magenta
    fade_on_empty = false
    font_family = tijpset
    placeholder_text = <span allow_breaks="true" font_weight="bold" foreground="##fef1fdaa">●   ●   ●</span>
    hide_input = false
    position = 0, -320
    halign = center
    valign = center
}
{{- end }}
