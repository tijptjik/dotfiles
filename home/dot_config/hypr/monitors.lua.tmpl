-- LG TV - disabled
hl.monitor({
    output = "HDMI-A-1",
    disabled = true,
})

{{ else if .isLaptop -}}

-- Primary
hl.monitor({
    output = "eDP-1",
    mode = "3840x2400@60.00",
    position = "0x0",
    scale = 2,
})

-- Secondary
hl.monitor({
    output = "DP-2",
    mode = "1920x1080@60.00",
    position = "auto-right",
    scale = 1,
})

{{- end }}
