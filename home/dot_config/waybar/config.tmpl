[
  // Bar for eDP-1 (laptop) - full layout, overlay mode
  {
    "output": "eDP-1",
    "ipc": true,
    "mode": "hide",
    "layer": "top",
    "position": "bottom",
    "height": 40,
    "margin-bottom": 10,
    "spacing": 12,
    "modules-left": [
      "custom/crypto",
      "custom/mediaplayer"
    ],
    "modules-center": [
      "hyprland/workspaces"
    ],
    "modules-right": [
      "tray",
      "temperature",
      "network",
      "custom/vpn",
      "pulseaudio",
      "clock",
      "custom/quit"
    ],
    "hyprland/workspaces": {
      "format": "{icon} {name}",
      "on-click": "activate",
      "on-scroll-up": "hyprctl dispatch workspace e+1",
      "on-scroll-down": "hyprctl dispatch workspace e-1",
      "format-icons": {
        "default": "\uf10c",
        "active": "\uf111",
        "10": "\uf11b"
      },
      "sort-by": "number"
    },
    "custom/mediaplayer": {
      "format": "{0}",
      "escape": false,
      "return-type": "json",
      "max-length": 60,
      "on-click": "playerctl -p Feishin play-pause",
      "on-click-right": "killall Feishin",
      "smooth-scrolling-threshold": 2,
      "on-scroll-down": "playerctl -p Feishin next",
      "on-scroll-up": "playerctl -p Feishin previous",
      "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null",
      "exec-if": "pgrep Feishin"
    },
    "custom/crypto": {
      "format": "{}",
      "interval": 600,
      "return-type": "json",
      "exec": "$HOME/.config/waybar/crypto/waybar_crypto.py",
      "exec-if": "ping pro-api.coinmarketcap.com -c1"
    },
    "tray": {
      "icon-size": 21,
      "spacing": 10
    },
    "temperature": {
      "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon",
      "input-filename": "temp1_input",
      "warning-threshold": 60,
      "critical-threshold": 80,
      "format": "{icon} {temperatureC}°C",
      "format-critical": "󰸁 {temperatureC}°C",
      "format-icons": ["󱃃", "󰔏", "󱃂"]
    },
    "network": {
      "format": "{ifname}",
      "format-wifi": " {essid}",
      "format-ethernet": " {ifname}",
      "format-disconnected": "",
      "tooltip-format": "▲ {bandwidthDownBytes} ▼ {bandwidthUpBytes}",
      "tooltip-format-wifi": "▲ {bandwidthDownBytes} ▼ {bandwidthUpBytes} @ {signalStrength}%",
      "min-length": 16,
      "max-length": 32
    },
    "custom/vpn": {
      "format": "{}",
      "interval": 10,
      "on-click": "/opt/Mullvad\\ VPN/mullvad-gui",
      "on-click-right": "mullvad connect",
      "on-click-middle": "mullvad disconnect",
      "return-type": "json",
      "min-length": 3,
      "max-length": 3,
      "exec": "$HOME/.config/waybar/mullvad.py 2> /dev/null"
    },
    "clock": {
      "format": "{:%H:%M}",
      "format-alt": "{:%a %b %d}",
      "tooltip": true
    },
    "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-bluetooth": "{icon} {volume}%",
      "format-muted": "",
      "format-icons": {
        "headphone": "",
        "hands-free": "",
        "headset": "",
        "phone": "",
        "portable": "",
        "car": "",
        "default": ["", ""]
      },
      "scroll-step": 4,
      "on-click": "pavucontrol"
    },
    "custom/quit": {
      "format": " ",
      "tooltip": "uptime -p",
      "on-click-middle": "sudo shutdown -h now"
    }
  },

  // Bar for DP-4 (external) - workspaces only, overlay mode
  {
    "output": "DP-4",
    "ipc": true,
    "mode": "hide",
    "layer": "top",
    "position": "bottom",
    "height": 40,
    "spacing": 12,
    "modules-center": [
      "hyprland/workspaces"
    ],
    "hyprland/workspaces": {
      "format": "{icon} {name}",
      "on-click": "activate",
      "on-scroll-up": "hyprctl dispatch workspace e+1",
      "on-scroll-down": "hyprctl dispatch workspace e-1",
      "format-icons": {
        "default": "\uf10c",
        "active": "\uf111",
        "10": "\uf11b"
      },
      "sort-by": "number"
    }
  }
]
