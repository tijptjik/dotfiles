@import "colors.css";

* {
  font-size: 14px;
  /* Defined in ~/.config/fontconfig/fonts.conf */
  font-family: "tijpset";
  color: @base05;
  background: none;
}

window#waybar {
    color: @base05;
    opacity: 0.95;
    border-radius: 10px;
}

window#waybar > box > box > widget > * {
  background-color: @base01;
}

tooltip {
  background: @base02;
}

tooltip label {
  font-family: "Noto Sans Mono";
}

/* Modules */

.modules-left {
/*  margin : 24px 0 0 24px;*/
}

.modules-center {
}

.modules-right {
/*  margin : 24px 24px 0 0;*/
}

/* Widgets */

.modules-right > widget > *,
.modules-center > widget > *,
.modules-left > widget > * {
  padding: 6px 12px;
}

/* Laptop islands are intentionally more compact than the desktop layout. */
window#waybar.laptop .modules-right > widget > *,
window#waybar.laptop .modules-center > widget > *,
window#waybar.laptop .modules-left > widget > * {
  padding-top: 2px;
  padding-bottom: 2px;
}

/* Workspaces */

#workspaces {
  padding: 5px 7px 5px 7px;
  border-radius: 10px;
}

window#waybar.laptop #workspaces {
  padding-top: 1px;
  padding-bottom: 1px;
}

/* Keep the Wi-Fi name and Mullvad indicator as one compact island. */
window#waybar.laptop #network {
  margin-right: 0;
  padding-left: 12px;
  padding-right: 8px;
}

/* Keep the notification controls aligned at the laptop bar's compact scale. */
window#waybar.laptop #custom-caffeine,
window#waybar.laptop #custom-nightlight {
  font-size: 23px;
}

#workspaces button {
  padding: 0 5px;
}

#workspaces button.active * {
  color: @base0E;
}

#workspaces button,
#workspaces button:hover {
    -gtk-icon-effect:none;
    -gtk-icon-shadow:none;
    transition: none;
    text-shadow: none;
    box-shadow: none;
    border: none;
}

/* Custom : Spotify */

#custom-spotify {
  padding: 0 12px;
  border-radius: 10px;
}

/* Custom : Crypto */

#custom-crypto {
  margin-right: 12px;
  border-radius: 10px;
}

/* Custom : Codex */

#custom-codex {
  margin-right: 12px;
  border-radius: 10px;
}

/* Tray */

#tray {
  color: @base05;
  margin-right: 12px;
  border-radius: 10px;

}

#tray > widget > image {
  color: @base05;
}

/* Pill Left  */
#temperature,
#network,
#clock {
  border-bottom-left-radius: 10px;
  border-top-left-radius: 10px;
}

/* Pill Right  */
#custom-vpn {
  border-top-right-radius: 10px;
  border-bottom-right-radius: 10px;
  margin-left: -12px;
  margin-right: 12px;
}

#temperature,
#pulseaudio {
  margin-right: 12px;
  border-radius: 10px;
}

#custom-notifications {
  margin-right: 0;
  border-top-left-radius: 10px;
  border-bottom-left-radius: 10px;
  border-top-right-radius: 0;
  border-bottom-right-radius: 0;
}

#clock {
  margin-right: 12px;
  border-radius: 10px;
}

#custom-notifications.paused * {
  color: @base03;
}

#custom-notifications,
#custom-caffeine {
  min-width: 18px;
  padding-left: 11px;
  padding-right: 11px;
}

#custom-caffeine {
  margin: 0;
  border-radius: 0;
}

#custom-nightlight {
  min-width: 18px;
  margin: 0;
  padding-left: 11px;
  padding-right: 11px;
  border-top-right-radius: 10px;
  border-bottom-right-radius: 10px;
}

/* Desktop status bar grouping */
window#waybar.desktop-status #network {
  margin-right: 0;
  border-top-left-radius: 10px;
  border-bottom-left-radius: 10px;
  border-top-right-radius: 0;
  border-bottom-right-radius: 0;
}

window#waybar.desktop-status #custom-vpn {
  margin-left: -12px;
  margin-right: 12px;
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
  border-top-right-radius: 10px;
  border-bottom-right-radius: 10px;
}

window#waybar.desktop-status #pulseaudio {
  margin-right: 0;
  border-top-left-radius: 10px;
  border-bottom-left-radius: 10px;
  border-top-right-radius: 0;
  border-bottom-right-radius: 0;
}

window#waybar.desktop-status #clock {
  margin-right: 0;
  border-radius: 0;
}

window#waybar.desktop-status #custom-codex {
  margin-right: 12px;
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
  border-top-right-radius: 10px;
  border-bottom-right-radius: 10px;
}

window#waybar.desktop-status #custom-quit {
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
  border-top-right-radius: 10px;
  border-bottom-right-radius: 10px;
}

/* Temperature */

#temperature.warning * {
    color: @base08;
}

#temperature.critical * {
    color: @base0F;
}
