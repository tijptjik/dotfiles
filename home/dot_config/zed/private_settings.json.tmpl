// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  {{ if .isDesktop -}}
  "diff_view_style": "split",
  {{ else if .isLaptop -}}
  "diff_view_style": "unified",
  {{ end -}}
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "prettier": {
    "allowed": true
  },
  "formatter": {
    "external": {
      "command": "bun run biome",
      "arguments": [
        "format",
        "--write",
        "--stdin-file-path={buffer_path}"
      ]
    }
  },
    "edit_predictions": {
        "provider": "mercury"
    },
    "ui_font_size": 19.0,
    "buffer_line_height": "comfortable",
    "format_on_save": "off",
    "code_actions_on_format": {
        "source.organizeImports.biome": true,
        "source.fixAll.biome": true
    },
    "lsp": {
        "vtsls": {
            "settings": {
                "typescript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always"
                    }
                },
                "javascript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always"
                    }
                }
            },
            "enable_lsp_tasks": true
        },
        "biome": {
            "binary": {
                "path": "{{ .chezmoi.homeDir }}/.bun/bin/biome",
                "arguments": ["lsp-proxy"]
            },
            "settings": {
                "require_config_file": true
            }
        },
        "tailwindcss-language-server": {
          "settings": {
            "classFunctions": ["cx", "clsx"],
            "experimental": {
                "classRegex": ["cx\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
              }
          }
        },
        "vscode-css-language-server": {
      		"settings": {
         			"css": {
          				"lint": {
         					"unknownAtRules": "ignore"
          				}
         			}
      		}
     	}
    },
    "lsp_document_colors": "background",
    "file_types": {
      "JSONC": ["**/.zed/**/*.json", "**/zed/**/*.json", "**/Zed/**/*.json", "**/.vscode/**/*.json","*.json.tmpl"],
      "YAML": ["**/waybar/config.tmpl"],
      "TOML": ["**/dunst/dunstrc.tmpl"],
      "Shell Script": [".env.*"],
      "Fish" : ["*.fish.tmpl", "*.yaml.tmpl", "*.yml.tmpl", "*.conf", "*.conf.tmpl","private_sshd_config"]
    },
    "languages": {
        "Markdown": {
            "show_edit_predictions": false,
            "formatter": "prettier",
            "format_on_save": "on"
        },
        "JavaScript": {
            "formatter": { "language_server": { "name": "biome" } },
            "code_actions_on_format": {
                "source.fixAll.biome": true,
                "source.organizeImports.biome": false
            }
        },
        "TypeScript": {
            "formatter": { "language_server": { "name": "biome" } },
            "code_actions_on_format": {
                "source.fixAll.biome": true,
                "source.organizeImports.biome": true
            }
        },
        "Svelte": { "formatter": { "language_server": { "name": "biome" } },
          "code_actions_on_format": {
            "source.fixAll.biome": true,
            "source.organizeImports.biome": false
          }
        },
        "JSON": {
            "formatter": { "language_server": { "name": "biome" } },
            "code_actions_on_format": {
                "source.fixAll.biome": true
            }
        },
        "JSONC": {
            "formatter": { "language_server": { "name": "biome" } },
            "code_actions_on_format": {
                "source.fixAll.biome": true
            }
        },
        "CSS": {
          "formatter": { "language_server": { "name": "biome" } } }
    },
    "project_panel": {
        "dock": "left",
        "hide_gitignore": false
    },
    "git_panel": {
        "group_by": "none",
        "sort_by": "path",
        "show_count_badge": true,
        "diff_stats": true,
        "folder_icons": false,
        "file_icons": false,
        "dock": "left",
        "tree_view": true
    },
    "agent": {
        "commit_message_instructions": "Use the Conventional Commits format: <type>(<scope>): <description>. Strip markdown backticks and trim. Subject must not start lower-case.",
        "commit_message_model": {
          "provider": "openai-subscribed",
          "model": "gpt-5.6-luna",
          "enable_thinking": false
        },
        "sidebar_side": "right",
        "dock": "right",
        "inline_assistant_model": {
          "provider": "openai",
          "model": "gpt-5.6-luna",
          "enable_thinking": false
        },
        "tool_permissions": {
            "default": "allow"
        },
        "show_turn_stats": true,
        "use_modifier_to_send": true,
        "play_sound_when_agent_done": "always",
        "default_model": {
          "provider": "openai",
          "model": "gpt-5.6-luna",
          "enable_thinking": true
        },
        "model_parameters": []
    },
    "agent_servers": {
    "pi-acp": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "codex-acp": {
      "favorite_config_option_values": {
        "reasoning_effort": [
          "medium"
        ],
        "model": [
          "gpt-5.6-terra"
        ],
        "mode": [
          "agent",
          "agent-full-access"
        ]
      },
      "default_config_options": {
        "fast-mode": false,
        "reasoning_effort": "high",
        "model": "gpt-5.6-terra",
        "mode": "read-only"
      },
      "type": "registry"
    }
  },
    "context_servers": {
        "mcp-server-context7": {
            "enabled": true,
            "settings": {
                "context7_api_key": {{ (bitwardenSecrets "22a5479c-f2de-43e1-9547-b3ec001d508b").value | quote}}
            }
        }
    },
    "icon_theme": "JetBrains New UI Icons (Dark)",
    "vim_mode": false,
    "base_keymap": "Cursor",
    "buffer_font_family": ".ZedMono",
    "buffer_font_weight": 400.0,
    "buffer_font_size": 18.0,
    "buffer_font_features": {
      "calt": true,
      "ss13" : true
    },
    "theme": {
        "mode": "dark",
        "light": "One Dark",
        "dark": "Rosé Punk"
    }
}
